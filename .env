# Local backup configuration
# Primary local backup (existing project backup store)
INVENTORY_BACKUP_PRIMARY=/Users/intuitivecreations2705gmail.com/Downloads/GITHUB REPO/REAL/REAL-INVENTORY-WIN/REAL-ED-INVENTORY-main/inventory_app/backups

# Secondary backup target on external SSD volume "2000 MASTER"
