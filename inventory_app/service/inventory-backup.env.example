# Copy to /etc/default/inventory-backup on server
DB_PATH=/opt/real-ed-inventory/sql_inventory_master.db
BACKUP_PRIMARY=/mnt/backup1
BACKUP_SECONDARY=/mnt/backup2
BACKUP_RETENTION_DAYS=30
BACKUP_OFFSITE_DIR=
INVENTORY_PRECHANGE_BACKUP_ENABLED=true
INVENTORY_PRECHANGE_BACKUP_REQUIRED=true
INVENTORY_PRECHANGE_BACKUP_INTERVAL_S=86400
INVENTORY_STARTUP_DAILY_BACKUP_ENABLED=true
