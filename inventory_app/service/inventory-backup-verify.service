[Unit]
Description=Inventory DB backup verification
After=inventory-backup.service

[Service]
Type=oneshot
User=inventory
Group=inventory
EnvironmentFile=-/etc/default/inventory-backup
ExecStart=/bin/bash -lc '/opt/real-ed-inventory/inventory_app/scripts/verify_backup.sh "${BACKUP_PRIMARY}"'

[Install]
WantedBy=multi-user.target
